generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// 用户
// ============================================================
model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  department  String?
  role        String   @default("employee")
  passwordHash String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions    AgentSession[]
  events      CalendarEvent[]
  expenses    Expense[]
  todos       Todo[]
}

// ============================================================
// Agent 会话
// ============================================================
model AgentSession {
  id             String   @id @default(cuid())
  userId         String
  title          String?
  currentIntent  String?
  taskStatus     String   @default("active")
  contextJson    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User             @relation(fields: [userId], references: [id])
  messages       AgentMessage[]
  toolCalls      AgentToolCall[]
  confirmations  ConfirmationRequest[]
}

// ============================================================
// Agent 消息记录
// ============================================================
model AgentMessage {
  id          String   @id @default(cuid())
  sessionId   String
  role        String
  type        String   @default("text")
  content     String
  metadata    String?
  createdAt   DateTime @default(now())

  session     AgentSession @relation(fields: [sessionId], references: [id])
}

// ============================================================
// Agent 工具调用日志
// ============================================================
model AgentToolCall {
  id            String   @id @default(cuid())
  sessionId     String
  stepId        String?
  toolName      String
  inputJson     String
  outputJson    String?
  status        String
  errorMessage  String?
  createdAt     DateTime @default(now())

  session       AgentSession @relation(fields: [sessionId], references: [id])
}

// ============================================================
// 日程事件
// ============================================================
model CalendarEvent {
  id            String   @id @default(cuid())
  userId        String
  title         String
  description   String?
  participants  String?
  startTime     DateTime
  endTime       DateTime
  location      String?
  status        String   @default("draft")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])
}

// ============================================================
// 费用报销
// ============================================================
model Expense {
  id              String   @id @default(cuid())
  userId          String
  expenseType     String
  amount          Float?
  currency        String   @default("CNY")
  expenseDate     DateTime?
  city            String?
  projectId       String?
  description     String?
  invoiceFileIds  String?
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
}

// ============================================================
// 用户确认请求
// ============================================================
model ConfirmationRequest {
  id          String   @id @default(cuid())
  sessionId   String
  action      String
  summary     String
  payload     String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session     AgentSession @relation(fields: [sessionId], references: [id])
}

// ============================================================
// 任务待办
// ============================================================
model Todo {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  priority    String    @default("medium")
  dueDate     DateTime?
  tags        String?
  assignee    String?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
}